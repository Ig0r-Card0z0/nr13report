# ── Backend (NestJS) ─────────────────────────────────
NODE_ENV=production
PORT=9000
# URL do frontend (para CORS)
FRONTEND_URL=https://seudominio.com.br

# ── Frontend (Next.js) ───────────────────────────────
# URL pública da API (usada pelo browser)
NEXT_PUBLIC_API_URL=https://seudominio.com.br

# ── Docker ───────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:9000   # dev local com docker
# FRONTEND_URL=http://localhost:9001          # dev local com docker
